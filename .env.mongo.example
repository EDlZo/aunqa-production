# ============================================
# MongoDB + MinIO + JWT Configuration
# ============================================

# MongoDB
# Local:  mongodb://localhost:27017/aunqa_db
# Server: mongodb://username:password@your-server-ip:27017/aunqa_db
MONGO_URI=mongodb://localhost:27017/aunqa_db

# JWT
# ใช้ key ที่ยาวและซับซ้อน ห้ามเปิดเผย
JWT_SECRET=change_this_to_a_very_long_random_secret_key_at_least_32_chars

# MinIO
# MINIO_ENDPOINT = IP หรือ domain ของ MinIO server (ไม่ต้องใส่ http://)
MINIO_ENDPOINT=localhost
# MINIO_PORT = port ของ MinIO API (ไม่ใช่ console)
MINIO_PORT=9000
# MINIO_ACCESS_KEY = username ของ MinIO
MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY = password ของ MinIO
MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET = ชื่อ bucket ที่จะเก็บไฟล์
MINIO_BUCKET=aunqa-files
# MINIO_USE_SSL = true ถ้าใช้ HTTPS, false สำหรับ local
MINIO_USE_SSL=false

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
