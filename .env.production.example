# ============================================
# Production Environment Template
# Copy to .env and fill in real values
# ============================================

# MongoDB (use strong password)
MONGO_URI=mongodb://user:password@your-mongo-host:27017/aunqa_db?authSource=admin

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET

# MinIO (change from defaults!)
MINIO_ENDPOINT=your-minio-host
MINIO_PORT=9000
MINIO_ACCESS_KEY=REPLACE_WITH_STRONG_KEY
MINIO_SECRET_KEY=REPLACE_WITH_STRONG_SECRET
MINIO_BUCKET=aunqa-files
MINIO_USE_SSL=true

# Server
PORT=5000
NODE_ENV=production
CORS_ORIGIN=https://your-production-domain.com
VITE_API_BASE_URL=https://your-production-domain.com
