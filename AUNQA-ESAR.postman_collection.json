            "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));",
            "if (pm.response.json().length > 0) pm.collectionVariables.set('user_id', pm.response.json()[0].id);"
          ], "type": "text/javascript" }}],
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{base_url}}/api/users" }
