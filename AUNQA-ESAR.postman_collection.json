  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login - System Admin",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const json = pm.response.json();",
            "  if (json.token) {",
            "    pm.collectionVariables.set('token', json.token);",
            "    pm.test('Login success + token saved', () => pm.expect(json.success).to.be.true);",
            "  }",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/login",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin@example.com\",\n  \"password\": \"yourpassword\",\n  \"role\": \"system_admin\"\n}" }
          }
        },
        {
          "name": "Login - Reporter",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const json = pm.response.json();",
            "  if (json.token) pm.collectionVariables.set('token', json.token);",
            "  pm.test('Login success', () => pm.expect(json.success).to.be.true);",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/login",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"reporter@example.com\",\n  \"password\": \"yourpassword\",\n  \"role\": \"reporter\"\n}" }
          }
        },
        {
          "name": "Login - Invalid (expect 401)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Should return 401', () => pm.expect(pm.response.code).to.equal(401));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/login",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"wrong@example.com\",\n  \"password\": \"wrongpassword\",\n  \"role\": \"system_admin\"\n}" }
          }
        }
      ]
    },
    {
      "name": "🏥 Health",
      "item": [
        {
          "name": "Ping",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Server OK', () => pm.expect(pm.response.json().ok).to.be.true);",
            "pm.test('DB connected', () => pm.expect(pm.response.json().db).to.be.true);",
            "pm.test('Storage is minio', () => pm.expect(pm.response.json().storage).to.equal('minio'));"
          ], "type": "text/javascript" }}],
          "request": { "method": "GET", "url": "{{base_url}}/api/ping" }
        }
      ]
    },
    {
      "name": "👥 Users",
