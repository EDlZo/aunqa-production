# ============================================
# MongoDB
# ============================================
MONGO_URI=mongodb://localhost:27017/aunqa_db

# ============================================
# JWT — เปลี่ยนเป็น secret ที่ปลอดภัยก่อน deploy
# ============================================
JWT_SECRET=change_this_to_a_secure_random_secret

# ============================================
# MinIO
# ============================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=change_this
MINIO_SECRET_KEY=change_this
MINIO_BUCKET=aunqa-files
MINIO_USE_SSL=false

# ============================================
# Server
# ============================================
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ============================================
# Frontend (Vite build-time)
# ============================================
VITE_API_BASE_URL=http://localhost:5000

# ============================================
# Deployment (GitLab CI variables — ไม่ต้องใส่ที่นี่)
# ============================================
# FRONTEND_HOST=aunqa.wrf.rmutsv.app
# BACKEND_HOST=aunqa-api.wrf.rmutsv.app
# SWARMPIT_URL=https://swarmpit.wrf.rmutsv.app
# SWARMPIT_TOKEN=<token>
# CI_REGISTRY_USER=<user>
# CI_REGISTRY_PASSWORD=<password>
